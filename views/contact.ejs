<%- include('partials/header') %>

  <section class="page-header">
    <h1>Contact Me</h1>
    <p>I'd love to help you plan your next adventure!</p>
  </section>

  <section class="section">
    <p class="contact-intro">
      Fill out the form below to tell me about your dream vacation, and I'll get back to you
      within 24 hours. Whether you have a specific destination in mind or need inspiration,
      I'm here to help!
    </p>

    <div class="form-embed">
      <iframe
        src="https://docs.google.com/forms/d/e/1FAIpQLSd_4hSr8TDg7PM-vsyJltGtjOdUWUc05kJFJoq3LkQPiOhCnQ/viewform?embedded=true"
        title="Travel Inquiry Form"
        loading="lazy">
        Loading form...
      </iframe>
    </div>

    <div class="form-link">
      <p style="margin-bottom: 1rem; color: var(--text-muted);">
        Having trouble seeing the form? Open it directly:
      </p>
      <a
        href="https://docs.google.com/forms/d/e/1FAIpQLSd_4hSr8TDg7PM-vsyJltGtjOdUWUc05kJFJoq3LkQPiOhCnQ/viewform"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-teal">
        Open Form in New Tab
      </a>
    </div>
  </section>

<%- include('partials/footer') %>
