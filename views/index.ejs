<%- include('partials/header') %>

  <!-- HERO: Replace background-image in CSS or swap to a <video> tag -->
  <section class="hero bg-section bg-parallax" data-bg="hero">
    <!-- Optional: uncomment for video background
    <video class="bg-video" autoplay muted loop playsinline>
      <source src="/videos/hero-video.mp4" type="video/mp4">
    </video>
    -->
    <div class="bg-overlay"></div>
    <div class="bg-content">
      <h1>Tara Oltmans</h1>
      <p class="tagline">Your Personal Travel Agent</p>
      <p class="subtitle">Travelmation Travel Advisor &mdash; Turning dream vacations into reality</p>
      <a href="/contact" class="btn btn-coral">Plan Your Trip</a>
    </div>
  </section>

  <section class="section">
    <h2>About Me</h2>
    <div class="about-content">
      <div class="about-photo">
        <img src="/images/arizona-balloon-sunset-couple.jpeg" alt="Tara Oltmans - Travelmation Travel Agent">
      </div>
      <div class="about-text">
        <p>
          Hi, I'm Tara! I'm a travel advisor with Travelmation who believes the best trips are the ones you don't have to stress about. I got into this industry because I've always been the one planning vacations for my family &mdash; from Caribbean cruises to European adventures &mdash; and I realized I could help other families experience that same joy.
        </p>
        <p>
          I've planned trips across the globe for my own family &mdash; exploring the ruins of Ephesus in Turkey, watching the sunset over Santorini, wandering through the Colosseum in Rome, holding koalas in Australia, cruising the fjords of Milford Sound in New Zealand, and floating over the Arizona desert in a hot air balloon. Every trip has taught me something new about what makes a vacation truly unforgettable.
        </p>
        <p>
          Whether you're dreaming of a relaxing beach getaway, an action-packed cruise, or a once-in-a-lifetime international adventure, I'd love to put that experience to work for you. Let me handle the details so you can focus on making memories.
        </p>
      </div>
    </div>
  </section>

  <!-- GALLERY BANNER: Santorini photo with travel quote -->
  <div class="bg-section bg-section--tall bg-parallax" data-bg="gallery">
    <!-- Optional: uncomment for video background
    <video class="bg-video" autoplay muted loop playsinline>
      <source src="/videos/gallery-video.mp4" type="video/mp4">
    </video>
    -->
    <div class="bg-overlay bg-overlay--light"></div>
    <div class="bg-content">
      <div class="gallery-banner">
        <p class="gallery-quote">&ldquo;Travel is the only thing you buy that makes you richer.&rdquo;</p>
        <span class="gallery-attr">&mdash; Anonymous</span>
      </div>
    </div>
  </div>

  <!-- SPECIALTIES: Text blurb between the two photo sections -->
  <div class="bg-section bg-parallax" data-bg="specialties">
    <div class="bg-overlay"></div>
    <div class="bg-content">
      <section class="section">
        <h2>What I Specialize In</h2>
        <div class="specialties-blurb">
          <p>
            From Caribbean cruise itineraries and all-inclusive resort getaways to multi-country European tours and adventures in Australia and New Zealand, I specialize in building trips that match your style. Whether it's your first cruise or your tenth international trip, I'll find the right destinations, excursions, and experiences to make it yours.
          </p>
        </div>
      </section>
    </div>
  </div>

  <!-- CTA: Replace background-image in CSS with a travel photo -->
  <section class="cta-section bg-section bg-parallax" data-bg="cta">
    <!-- Optional: uncomment for video background
    <video class="bg-video" autoplay muted loop playsinline>
      <source src="/videos/cta-video.mp4" type="video/mp4">
    </video>
    -->
    <div class="bg-overlay"></div>
    <div class="bg-content">
      <h2>Ready to Start Planning?</h2>
      <p>Let's turn your travel dreams into a reality. Reach out today!</p>
      <a href="/contact" class="btn btn-coral">Get in Touch</a>
    </div>
  </section>

<%- include('partials/footer') %>
